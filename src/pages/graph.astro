---
import BaseLayout from '../layouts/BaseLayout.astro'
import KnowledgeGraph from '../components/KnowledgeGraph'
import { getAllNotes, buildGraphData } from '../lib/notes'
import BaseLayout from '../layouts/BaseLayout.astro'
import KnowledgeGraph from '../components/KnowledgeGraph'
import { getAllNotes, buildGraphData } from '../lib/notes'

const notes = getAllNotes()
const data = buildGraphData(notes)
---

<BaseLayout title="Knowledge Graph">
  <div class="graph-title flex h-[calc(100vh-80px)] flex-col">
  <div class="graph-title flex h-[calc(100vh-80px)] flex-col">
    <div class="mb-4">
      <h1
        class="from-fg to-accent-light mb-1 bg-linear-to-br bg-clip-text text-4xl font-bold text-transparent"
      >
      <h1
        class="from-fg to-accent-light mb-1 bg-linear-to-br bg-clip-text text-4xl font-bold text-transparent"
      >
        Knowledge Graph
      </h1>
      <p class="text-muted text-sm">
        {data.nodes.length} notes · {data.links.length} connections · click any node to open the note
      </p>
    </div>

    <div class="border-border min-h-125 flex-1 overflow-hidden rounded-xl border">
      <KnowledgeGraph data={data} client:only="react" />
    </div>
  </div>
</BaseLayout>
