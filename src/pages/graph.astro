---
import BaseLayout from '../layouts/BaseLayout.astro';
import KnowledgeGraph from '../components/KnowledgeGraph';
import { getAllNotes, buildGraphData } from '../lib/notes';

const notes = getAllNotes();
const { nodes, edges } = buildGraphData(notes);
---

<BaseLayout title="Knowledge Graph">
  <div class="flex flex-col h-[calc(100vh-80px)]">
    <div class="mb-4">
      <h1 class="text-4xl font-bold bg-linear-to-br from-fg to-accent-light bg-clip-text text-transparent mb-1">
        Knowledge Graph
      </h1>
      <p class="text-muted text-sm">
        {nodes.length} notes · {edges.length} connections · click any node to open the note
      </p>
    </div>

    <div class="flex-1 border border-border rounded-xl overflow-hidden min-h-[500px]">
      <KnowledgeGraph nodes={nodes} edges={edges} client:only="react" />
    </div>
  </div>
</BaseLayout>
