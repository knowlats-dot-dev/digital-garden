---
import BaseLayout from '../../layouts/BaseLayout.astro';
import KnowledgeGraph from '../../components/KnowledgeGraph';
import { getAllNotes, getNoteBySlug, buildGraphData, wikilinkToHtml } from '../../lib/notes';
import { unified } from 'unified';
import remarkParse from 'remark-parse';
import remarkHtml from 'remark-html';
import Graph from '../graph.astro';

export async function getStaticPaths() {
  const notes = getAllNotes();
  return notes.map((note) => ({ params: { slug: note.slug } }));
}

const { slug } = Astro.params;
const note = getNoteBySlug(slug!);
if (!note) return Astro.redirect('/');

const allNotes = getAllNotes();
const validSlugs = new Set(allNotes.map((n) => n.slug));
const { nodes, edges } = buildGraphData(allNotes);

const contentWithLinks = wikilinkToHtml(note.content, validSlugs);
const result = await unified().use(remarkParse).use(remarkHtml, { sanitize: false }).process(contentWithLinks);
const html = String(result);

const formattedDate = note.date
  ? new Date(note.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : '';

const backlinkedNotes = allNotes.filter((n) => note.backlinks.includes(n.slug));
const outlinkNotes = allNotes.filter((n) => note.outlinks.includes(n.slug));
---

<BaseLayout title={note.title}>
  <div class="grid grid-cols-1 lg:grid-cols-[1fr_380px] gap-8 items-start">

    <article class="min-w-0">
      <header class="mb-8 pb-6 border-b border-border">
        {formattedDate && <div class="text-xs text-muted mb-2">{formattedDate}</div>}
        <h1 class="text-4xl font-bold leading-tight mb-3 bg-gradient-to-br from-fg to-accent-light bg-clip-text text-transparent">
          {note.title}
        </h1>
        {note.tags.length > 0 && (
          <div class="flex flex-wrap gap-1.5">
            {note.tags.map((tag) => (
              <a
                href={`/tags/${tag}`}
                class="inline-block bg-surface2 border border-border text-muted text-xs px-2 py-0.5 rounded-full no-underline transition-all duration-150 hover:border-accent hover:text-accent-light hover:no-underline"
              >
                #{tag}
              </a>
            ))}
          </div>
        )}
      </header>

      <div class="prose" set:html={html} />

      {(backlinkedNotes.length > 0 || outlinkNotes.length > 0) && (
        <footer class="mt-12 pt-6 border-t border-border flex flex-wrap gap-8">
          {outlinkNotes.length > 0 && (
            <section>
              <h3 class="text-[0.8rem] font-semibold uppercase tracking-[0.08em] text-muted mb-2">Links to</h3>
              <ul class="list-none p-0 flex flex-col gap-1">
                {outlinkNotes.map((n) => (
                  <li><a href={`/notes/${n.slug}`} class="text-sm text-accent-light">{n.title}</a></li>
                ))}
              </ul>
            </section>
          )}
          {backlinkedNotes.length > 0 && (
            <section>
              <h3 class="text-[0.8rem] font-semibold uppercase tracking-[0.08em] text-muted mb-2">Linked from</h3>
              <ul class="list-none p-0 flex flex-col gap-1">
                {backlinkedNotes.map((n) => (
                  <li><a href={`/notes/${n.slug}`} class="text-sm text-accent-light">{n.title}</a></li>
                ))}
              </ul>
            </section>
          )}
        </footer>
      )}
    </article>

    <aside id="graph-aside" class="bg-surface border border-border rounded-xl overflow-hidden lg:sticky lg:top-20 max-lg:fixed max-lg:inset-0 max-lg:rounded-none max-lg:z-[110] max-lg:shadow-2xl max-lg:hidden">
      <div class="flex justify-between items-center px-4 py-3 border-b border-border text-[0.82rem] font-semibold text-muted">
        <span>Knowledge Graph</span>
        <a href="/graph" class="text-[0.78rem] text-accent-light">Full view →</a>
      </div>
      <div class="h-100 max-lg:h-[calc(100%-3rem)]">
        <KnowledgeGraph nodes={nodes} edges={edges} activeSlug={slug} client:only="react" />
      </div>
    </aside>

    <button id="graph-toggle" class="fixed bottom-6 right-6 lg:hidden z-120 bg-surface border border-border rounded-full p-2.5 shadow-lg text-muted hover:text-accent-light transition-colors" aria-label="Toggle graph"></button>

    <script>
      const toggle = document.getElementById('graph-toggle');
      const aside = document.getElementById('graph-aside');

      const graphIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
        <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
      </svg>`;
      const closeIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>`;

      function updateIcon(isHidden: boolean) {
        if (toggle) toggle.innerHTML = isHidden ? graphIcon : closeIcon;
      }

      updateIcon(true);

      toggle?.addEventListener('click', () => {
        const isHidden = aside?.classList.contains('max-lg:hidden');
        aside?.classList.toggle('max-lg:hidden', !isHidden);
        updateIcon(!isHidden);
        if (isHidden) window.dispatchEvent(new Event('resize'));
      });
    </script>

  </div>
</BaseLayout>
