---
interface Props {
  slug: string
  title: string
  date: string
  tags: string[]
  excerpt: string
}

const { slug, title, date, tags, excerpt } = Astro.props
const formattedDate = date
  ? new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
  : ''
---

<a
  href={`/notes/${slug}`}
  class="note-card bg-surface border-border text-fg hover:border-accent hover:text-fg flex flex-col rounded-[10px] border px-5 py-4 no-underline transition-[border-color,transform,box-shadow] duration-150 hover:-translate-y-0.5 hover:no-underline hover:shadow-[0_4px_20px_color-mix(in_oklch,var(--color-accent)_15%,transparent)]"
>
  <div class="mb-2 flex items-baseline justify-between gap-2">
    <h2 class="text-accent text-[1rem] leading-snug font-semibold">{title}</h2>
    {
      formattedDate && (
        <time class="text-muted shrink-0 text-[0.72rem] whitespace-nowrap">{formattedDate}</time>
      )
    }
  </div>
  <p class="text-muted mb-3 line-clamp-3 flex-1 text-[0.82rem] leading-relaxed">{excerpt}</p>
  {
    tags.length > 0 && (
      <div class="mt-auto flex flex-wrap gap-1.5">
        {tags.map((tag) => (
          <span class="bg-surface2 border-border text-muted inline-block rounded-full border px-2 py-0.5 text-[0.68rem]">
            #{tag}
          </span>
        ))}
      </div>
    )
  }
</a>
